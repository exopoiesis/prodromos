# Normalize all text files to LF in the repository (checkout may differ per
# core.autocrlf, but the stored blobs are always LF).
* text=auto eol=lf

# Explicit text types
*.py    text eol=lf
*.pyi   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sh    text eol=lf
*.cif   text eol=lf
*.xyz   text eol=lf

# Binary (never normalize / never diff as text)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.pdf   binary
*.npy   binary
*.npz   binary
*.gz    binary
*.zip   binary
*.pkl   binary
